<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nguyễn Thị Ngân | Portfolio</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
    <style>
        :root { --primary: #1e3a8a; --secondary: #3b82f6; --bg: #f8fafc; --text: #1f2937; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; margin: 0; }
        .container { max-width: 900px; margin: 0 auto; padding: 40px 20px; }
        
        /* Header */
        header { border-bottom: 2px solid var(--primary); padding-bottom: 20px; margin-bottom: 30px; }
        header h1 { color: var(--primary); margin: 0; font-size: 2.5rem; }
        .contact-bar { display: flex; gap: 20px; flex-wrap: wrap; margin-top: 10px; font-size: 0.9rem; }
        .contact-bar a { color: var(--text); text-decoration: none; }

        /* Sections */
        section { margin-bottom: 40px; }
        h2 { color: var(--primary); border-left: 5px solid var(--primary); padding-left: 15px; text-transform: uppercase; font-size: 1.2rem; margin-bottom: 20px; }
        
        /* Education & Projects */
        .item { margin-bottom: 25px; }
        .item-header { display: flex; justify-content: space-between; font-weight: bold; color: var(--primary); }
        .sub-text { color: #6b7280; font-style: italic; margin-bottom: 10px; }
        
        /* CÁI ẢNH MÀ M MUỐN ĐÂY */
        .project-img { 
            width: 100%; max-width: 300px; border-radius: 10px; 
            margin: 15px 0; border: 1px solid #ddd; 
        }

        /* Skills Grid */
        .skills-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; }
        .skill-tag { background: #e2e8f0; padding: 4px 12px; border-radius: 15px; font-size: 0.85rem; display: inline-block; margin: 3px; }

        @media (max-width: 600px) { .item-header { flex-direction: column; } }
    </style>
</head>
<body>

<div class="container">
    <header>
